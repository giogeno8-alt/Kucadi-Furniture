# =============================================================================
# KUCADI FURNITURE — Environment Variables
# Copy file ini ke .env dan isi nilainya
# CP: cp .env.example .env
# =============================================================================

# --- Django ---
# Secret key untuk production. Biarkan kosong untuk pakai default di settings.py
SECRET_KEY=

# --- Database ---
# Kosongkan untuk pakai SQLite default
# Untuk PostgreSQL: DATABASE_URL=postgres://user:pass@host:port/dbname
DATABASE_URL=

# --- Midtrans (Payment Gateway) ---
MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=False

# --- Render Deployment ---
# Diisi otomatis oleh Render, tidak perlu diubah manual
RENDER_EXTERNAL_HOSTNAME=
