# =============================================================================
# KUCADI FURNITURE — Environment Variables
# Copy file ini ke .env dan isi nilainya
# CP: cp .env.example .env
# =============================================================================

# --- Django ---
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True

# --- Hosts (comma-separated) ---
ALLOWED_HOSTS=localhost,127.0.0.1,KucadiFurnitures.pythonanywhere.com,kucadifurnitures.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://kucadifurnitures.pythonanywhere.com

# --- Database ---
# Kosongkan untuk SQLite default
# Untuk PostgreSQL: DATABASE_URL=postgres://user:pass@host:port/dbname
DATABASE_URL=

# --- Email ---
# Development: console backend (default)
# Production: smtp
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@kucadifurniture.com

# --- Midtrans (Payment Gateway) ---
MIDTRANS_MERCHANT_ID=your-merchant-id
MIDTRANS_CLIENT_KEY=your-client-key
MIDTRANS_SERVER_KEY=your-server-key
MIDTRANS_IS_PRODUCTION=False

# --- Google OAuth 2.0 ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
